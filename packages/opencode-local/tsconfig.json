{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "lib": ["esnext"],
    "types": ["node"],
    "noEmit": true,
    "allowJs": false,
    "jsx": "preserve"
  },
  "include": [
    "src/**/*.ts",
    "test/**/*.ts"
  ]
}
